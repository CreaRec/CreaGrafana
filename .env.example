# Server bootstrap only (copy to the deploy directory as .env).
# Deploy is via GitHub Actions on push to main — not from this machine.
# Local Mac: use GRAFANA_BIND=127.0.0.1

# Bind Grafana UI. Production: your Tailscale IP (e.g. 100.x.x.x). Never 0.0.0.0 on a public host.
GRAFANA_BIND=127.0.0.1

# Optional: bind Alloy UI the same way (leave empty to skip publishing 12345)
ALLOY_UI_BIND=127.0.0.1

GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=changeme

# Pinned image tags (bump deliberately)
GRAFANA_IMAGE=grafana/grafana:11.5.2
LOKI_IMAGE=grafana/loki:3.4.2
TEMPO_IMAGE=grafana/tempo:2.7.1
MIMIR_IMAGE=grafana/mimir:2.15.0
ALLOY_IMAGE=grafana/alloy:v1.7.5
LISTEN_PORTS_IMAGE=alpine:3.21
